{
  "manifest_version": 3,
  "name": "BunnyFlow Whisk",
  "version": "1.0.0",
  "description": "BunnyFlow session management for Google Whisk — session injection + account lock.",
  "permissions": [
    "cookies",
    "tabs",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://whisk.google.com/*",
    "https://*.replit.app/*",
    "https://*.replit.dev/*",
    "https://*.google.com/*"
  ],
  "background": {
    "service_worker": "wh_background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://whisk.google.com/*"],
      "js": ["wh_lock.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://whisk.google.com/*"],
      "js": ["wh_session.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
